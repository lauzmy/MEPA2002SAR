    <!-- ==================== WHEEL FRICTION ==================== -->
    <!-- Type-X mecanum: each wheel has high friction (mu) along the traction
         diagonal and ~zero friction (mu2) along the free-rolling roller axis.
         The diagonal MUST be expressed in the chassis (base_footprint) frame,
         otherwise the heavy motor->wheel rotations rotate fdir1 out of the
         XY plane and the strafe force vanishes — the symptom being
         "forward fine, strafe just spins".

         Pairing rule (Type-X): the two diagonally-opposite wheels share the
         same fdir1. FL & BR share one diagonal, FR & BL share the other.
         After the +π/2 yaw on base_footprint_to_base_link, the link names
         match physical positions:
             wheel_fl = physical FL  -> fdir1 ( 1, -1, 0)
             wheel_fr = physical FR  -> fdir1 ( 1,  1, 0)
             wheel_rl = physical BL  -> fdir1 ( 1,  1, 0)
             wheel_rr = physical BR  -> fdir1 ( 1, -1, 0) -->
    <gazebo reference="wheel_rl_link">  <!-- physical back-left -->
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>5.0</mu>
                        <mu2>0.0</mu2>
                        <fdir1 gz:expressed_in="base_footprint">1 1 0</fdir1>
                    </ode>
                </friction>
                <contact>
                    <ode>
                        <kp>1000000.0</kp>
                        <kd>1.0</kd>
                    </ode>
                </contact>
            </surface>
        </collision>
    </gazebo>
    <gazebo reference="wheel_fl_link">  <!-- physical front-left -->
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>5.0</mu>
                        <mu2>0.0</mu2>
                        <fdir1 gz:expressed_in="base_footprint">1 -1 0</fdir1>
                    </ode>
                </friction>
                <contact>
                    <ode>
                        <kp>1000000.0</kp>
                        <kd>1.0</kd>
                    </ode>
                </contact>
            </surface>
        </collision>
    </gazebo>
    <gazebo reference="wheel_rr_link">  <!-- physical back-right -->
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>5.0</mu>
                        <mu2>0.0</mu2>
                        <fdir1 gz:expressed_in="base_footprint">1 -1 0</fdir1>
                    </ode>
                </friction>
                <contact>
                    <ode>
                        <kp>1000000.0</kp>
                        <kd>1.0</kd>
                    </ode>
                </contact>
            </surface>
        </collision>
    </gazebo>
    <gazebo reference="wheel_fr_link">  <!-- physical front-right -->
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>5.0</mu>
                        <mu2>0.0</mu2>
                        <fdir1 gz:expressed_in="base_footprint">1 1 0</fdir1>
                    </ode>
                </friction>
                <contact>
                    <ode>
                        <kp>1000000.0</kp>
                        <kd>1.0</kd>
                    </ode>
                </contact>
            </surface>
        </collision>
    </gazebo>

    <!-- ==================== IMU SENSOR ==================== -->
    <gazebo reference="imu_link">
        <sensor name="imu_sensor" type="imu">
            <always_on>true</always_on>
            <update_rate>100</update_rate>
            <topic>/imu</topic>
            <!-- Force the published Imu msg's frame_id to a name that
                 actually exists in the TF tree (the URDF link `imu_link`,
                 broadcast by robot_state_publisher via the
                 base_link → upper_level_link → imu_link chain).
                 Without this, gz-sim auto-generates the long scoped name
                 "gregor/imu_link/imu_sensor", which has NO corresponding
                 TF, so MOLA's `imu_gravity_correction` cannot rotate the
                 measured gravity vector into base_link and falls back to
                 assuming an identity sensor pose. The result is that
                 gravity is reported in `imu_link` axes (yawed -90°
                 relative to base_link) — MOLA then re-levels the local
                 map every cycle and the cloud "tilts" with each turn. -->
            <gz_frame_id>imu_link</gz_frame_id>
            <imu>
                <angular_velocity>
                    <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></z>
                </angular_velocity>
                <linear_acceleration>
                    <x><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></z>
                </linear_acceleration>
            </imu>
        </sensor>
    </gazebo>

    <!-- ==================== LIDAR SENSOR ==================== -->
    <!-- Attached to the `laser` link, which is already positioned by the URDF
         kinematic chain (base_link → upper_level_link → [Upper-Level_Revolute-3]
         → lidar_mount_link → laser). Tilt in sim matches the real robot exactly. -->
    <gazebo reference="laser">
        <sensor name="lidar" type="gpu_lidar">
            <always_on>true</always_on>
            <update_rate>10</update_rate>
            <visualize>true</visualize>
            <topic>/scan</topic>
            <gz_frame_id>laser</gz_frame_id>
            <lidar>
                <scan>
                    <horizontal>
                        <samples>450</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                    <vertical>
                        <samples>1</samples>
                        <resolution>1</resolution>
                        <min_angle>0.0</min_angle>
                        <max_angle>0.0</max_angle>
                    </vertical>
                </scan>
                <range>
                    <min>0.12</min>
                    <max>12.0</max>
                    <resolution>0.01</resolution>
                </range>
                <!-- Tiny gaussian noise so synthetic walls don't yield
                     perfectly coplanar returns (which collapse GICP
                     normals in MOLA-LO's voxel grid). -->
                <noise type="gaussian">
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </lidar>
        </sensor>
    </gazebo>

    <!-- ==================== GAZEBO PLUGINS ==================== -->
    <gazebo>
        <!-- Mecanum drive: subscribes /cmd_vel, publishes odometry and TF.
             After the +π/2 yaw on base_footprint_to_base_link, the Fusion
             link names finally match physical position, so the wiring is
             the natural mapping. Wheelbase = front↔back X distance in
             base_footprint; wheel_separation = left↔right Y distance.
             Computed from the wheel sphere positions in base_footprint:
               front pair X = +0.080, back pair X = -0.065  →  wheelbase 0.145
               left  pair Y = +0.050, right pair Y = -0.050 →  separation 0.100 -->
        <plugin filename="gz-sim-mecanum-drive-system"
                name="gz::sim::systems::MecanumDrive">
            <front_left_joint>Motor-FL_Revolute-28</front_left_joint>
            <front_right_joint>Motor-FR_Revolute-27</front_right_joint>
            <back_left_joint>Motor-RL_Revolute-26</back_left_joint>
            <back_right_joint>Motor-RR_Revolute-22</back_right_joint>
            <wheelbase>0.145</wheelbase>
            <wheel_separation>0.100</wheel_separation>
            <wheel_radius>0.0375</wheel_radius>
            <topic>/cmd_vel</topic>
            <odom_topic>/wheel/odometry</odom_topic>
            <tf_topic>/model/gregor/tf</tf_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_footprint</child_frame_id>
            <odom_publish_frequency>50</odom_publish_frequency>
        </plugin>

        <!-- Publishes all joint states so robot_state_publisher and RViz stay in sync -->
        <plugin filename="gz-sim-joint-state-publisher-system"
                name="gz::sim::systems::JointStatePublisher">
        </plugin>

        <!-- Tilt joint position controller: receives /lidar_cmd_pos -->
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>Upper-Level_Revolute-3</joint_name>
            <topic>/lidar_cmd_pos</topic>
            <!-- Tuned for the lidar mount's tiny inertia at a 4 s
                 triangle reference: stiff P, no integrator (the reference
                 already covers the steady-state range), modest D for
                 damping. Old (10/0.1/0.1) lagged badly and oscillated. -->
            <p_gain>80.0</p_gain>
            <i_gain>0.0</i_gain>
            <d_gain>2.0</d_gain>
        </plugin>
    </gazebo>
</robot>