    <link name="wheel_fl_link">
        <inertial>
            <origin xyz="-0.000322 -0.026544 0.000171" rpy="0 0 0" />
            <mass value="0.151189" />
            <inertia ixx="7.28318e-05" iyy="9.24437e-05" izz="7.28283e-05" ixy="-1.46474e-07" iyz="3.16777e-07" ixz="0" />
        </inertial>
        <visual name="Mecanum-wheel-FL_visual">
            <origin xyz="-0.03739 -0.100023 -0.035225" rpy="-1.5708 0.785398 -1.5708" />
            <geometry>
                <mesh filename="package://gregor_description/meshes/Mecanum-wheel-FL.stl" scale="0.001 0.001 0.001" />
            </geometry>
            <material name="lidar_black"><color rgba="0.08 0.08 0.08 1.0"/></material>
        </visual>
        <!-- Smooth sphere collision: required for the gz mecanum-drive
             fdir1/mu2 friction trick to produce real sideways motion.
             Visual still uses the mecanum STL above so it looks correct.
             IMPORTANT: this <collision> MUST stay unnamed. The Gazebo
             URDF→SDF parser only merges the <gazebo reference=...><surface>
             friction extension into a wheel collision when the collision
             uses the parser's default lumped name. A custom name attribute
             here makes the merge silently fail and strafing dies. -->
        <collision>
            <origin xyz="0 -0.02654 0" rpy="0 0 0" />
            <geometry>
                <sphere radius="0.0375" />
            </geometry>
        </collision>
    </link>
