<?xml version='1.0' encoding='utf-8'?>
<robot name="gregor" xmlns:gz="http://gazebosim.org/schema">
    <link name="base_footprint"/>
    <!-- +π/2 yaw aligns Fusion's base_link axes with REP-103 so the
         MecanumDrive plugin's IK matches physics. See wiki: Hardware-Robot-Model. -->
    <joint name="base_footprint_to_base_link" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.025" rpy="0 0 1.5708"/>
    </joint>

