            <inertia ixx="2.6712475404684394e-05" iyy="1.2042060245804525e-05" izz="2.6712475404643194e-05" ixy="-1.0866814894591445e-70" iyz="9.215718466126788e-19" ixz="-5.421010862427522e-20" />
