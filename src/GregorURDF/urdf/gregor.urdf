            <origin xyz="0.013462007936543627 -0.019104984548618534 -0.00019999999999990693" rpy="3.252606517435962e-19 4.8572257327350556e-17 1.2490009027033014e-16" />
            <geometry>
                <mesh filename="package://gregor_description/meshes/Avstands-sensor-hoyre.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>
    <link name="motor_rl_link">
        <inertial>
            <origin xyz="-8.881784197001253e-18 0.02494272511608105 -2.938676235686444e-10" rpy="0.0 -0.0 0.0" />
            <mass value="0.15441088816550527" />
            <inertia ixx="2.6712475404684285e-05" iyy="1.2042060245804091e-05" izz="2.6712475404642815e-05" ixy="0.0" iyz="9.75781955236954e-19" ixz="0.0" />
        </inertial>
        <visual name="Motor-RL_visual">
            <origin xyz="-0.020062164065097678 0.001982999919935944 -2.7647439893030423e-10" rpy="1.5707963267948966 -6.591949208711876e-15 1.5707963267948968" />
            <geometry>
