            </geometry>
        </collision>
    </link>
    <link name="motor_rr_link">
        <inertial>
            <origin xyz="1.2878587085651815e-16 -0.024942724477164085 -1.203269146543562e-09" rpy="0.0 -0.0 0.0" />
