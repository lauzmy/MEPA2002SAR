    </link>
    <joint name="Chassie_Rigid-1" type="fixed">
        <origin xyz="0.00015423000372526423 -0.007561000130385147 -1.4210854715202004e-16" rpy="3.141592653589793 6.1584619237316516e-33 -1.5707963267948966" />
        <parent link="base_link" />
        <child link="battery_link" />
    </joint>
    <joint name="Chassie_Rigid-2" type="fixed">
        <origin xyz="0.00015423000372526423 -0.007561000130385147 0.007999999999999856" rpy="-3.2526065174564526e-19 6.1584619237316516e-33 -1.5707963267948966" />
        <parent link="base_link" />
        <child link="upper_level_link" />
    </joint>
    <joint name="Upper-Level_Revolute-3" type="revolute">
        <!-- Pure Z hinge above upper_level_link.
             rpy yaw = +π/2 cancels upper_level_link's -π/2 yaw,
             so the child frame is aligned with base_link at tilt=0.
             Axis (1,0,0) in this (now base-aligned) frame = base_link X,
             giving front/back tilt of the laser. -->
        <origin xyz="0 0 0.08375145" rpy="0 0 1.5707963267948966" />
        <parent link="upper_level_link" />
        <child link="lidar_mount_link" />
        <axis xyz="1 0 0" />
        <limit lower="-0.785398" upper="0.785398" effort="10.0" velocity="5.0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>
    <joint name="LiDAR-Mount_Rigid-4" type="fixed">
        <!-- Pure Z offset: laser sits ~6 mm above the hinge axis. -->
        <origin xyz="0 0 0.00615" rpy="0 0 3.141592653589793" />
        <parent link="lidar_mount_link" />
        <child link="laser" />
    </joint>
    <joint name="Upper-Level_Rigid-5" type="fixed">
        <origin xyz="0.057249999999999995 -0.03049246 0.056499999999999995" rpy="1.570796326794901 -0.0 0.0" />
        <parent link="upper_level_link" />
        <child link="camera_link" />
    </joint>
    <joint name="Upper-Level_Rigid-6" type="fixed">
        <origin xyz="0.057249999999999995 0.02750754 0.056499999999999995" rpy="1.5707963267948966 -0.0 0.0" />
        <parent link="upper_level_link" />
        <child link="thermal_camera_link" />
    </joint>
    <joint name="Upper-Level_Rigid-7" type="fixed">
        <origin xyz="0.0 0.0 0.04035000000000001" rpy="0.0 -0.0 0.0" />
        <parent link="upper_level_link" />
        <child link="imu_link" />
    </joint>
    <joint name="Upper-Level_Rigid-8" type="fixed">
        <origin xyz="-0.012 0.085 -0.014802099999999997" rpy="0.0 -0.0 0.0" />
        <parent link="upper_level_link" />
        <child link="range_left_link" />
    </joint>
    <joint name="Chassie_Rigid-9" type="fixed">
        <origin xyz="0.013000710003725262 -0.14062201013038508 -0.005000000000000142" rpy="-3.2526065174564526e-19 6.1584619237316516e-33 -1.5707963267948966" />
        <parent link="base_link" />
        <child link="range_front_link" />
    </joint>
    <joint name="Chassie_Rigid-11" type="fixed">
        <origin xyz="-0.012835639996274736 0.12549999986961483 -0.00800000000000015" rpy="3.141592653589793 6.1584619237316516e-33 -1.5707963267948966" />
        <parent link="base_link" />
        <child link="range_rear_link" />
    </joint>
    <joint name="Chassie_Rigid-21" type="fixed">
        <origin xyz="-0.04999999999627474 0.06499999986961483 -0.019000000000000152" rpy="1.5707963267948966 -1.5707963267948966 0" />
        <parent link="base_link" />
        <child link="motor_rr_link" />
    </joint>
    <joint name="Motor-RR_Revolute-22" type="continuous">
        <origin xyz="0.0 0.0 0.0" rpy="3.141592653589793 -0.0 0.0" />
        <parent link="motor_rr_link" />
        <child link="wheel_rr_link" />
        <axis xyz="0.0 -1.0 -4.022647846648095e-51" />
        <limit effort="50000" velocity="10"/>
        <dynamics damping="1.0" friction="1.0"/>
    </joint>
    <joint name="Chassie_Rigid-23" type="fixed">
        <origin xyz="-0.04999999999627474 -0.08000000013038511 -0.019000000000000152" rpy="-1.5707963267948968 -1.5707963267948966 0" />
        <parent link="base_link" />
        <child link="motor_fr_link" />
    </joint>
    <joint name="Chassie_Rigid-24" type="fixed">
        <origin xyz="0.05033753000372526 -0.08010768013038512 -0.019000000000000152" rpy="1.5707963267948966 -1.5707963267948966 0" />
        <parent link="base_link" />
        <child link="motor_fl_link" />
    </joint>
    <joint name="Chassie_Rigid-25" type="fixed">
        <origin xyz="0.050354650003725264 0.06471500986961483 -0.019000000000000152" rpy="1.5707963267948966 -1.5707963267948966 0" />
        <parent link="base_link" />
        <child link="motor_rl_link" />
    </joint>
    <joint name="Motor-RL_Revolute-26" type="continuous">
        <origin xyz="0.0 0.0 0.0" rpy="3.141592653589793 7.022514532037904e-97 3.503246160812043e-46" />
        <parent link="motor_rl_link" />
        <child link="wheel_rl_link" />
        <axis xyz="-3.503246160812043e-46 1.0 2.495984093634733e-46" />
        <limit effort="50000" velocity="10"/>
        <dynamics damping="1.0" friction="1.0"/>
    </joint>
    <joint name="Motor-FR_Revolute-27" type="continuous">
        <origin xyz="0.0 0.0 0.0" rpy="3.141592653589793 -0.0 0.0" />
        <parent link="motor_fr_link" />
        <child link="wheel_fr_link" />
        <axis xyz="0.0 -1.0 2.1209945128196103e-51" />
        <limit effort="50000" velocity="10"/>
        <dynamics damping="1.0" friction="1.0"/>
    </joint>
    <joint name="Motor-FL_Revolute-28" type="continuous">
        <origin xyz="0.0 0.0 0.0" rpy="-2.660190735689466e-33 -0.0 0.0" />
        <parent link="motor_fl_link" />
        <child link="wheel_fl_link" />
        <axis xyz="0.0 1.0 2.4034014453635364e-47" />
        <limit effort="50000" velocity="10"/>
        <dynamics damping="1.0" friction="1.0"/>
    </joint>
    <joint name="Upper-Level_Rigid-29" type="fixed">
        <origin xyz="0.01349606 -0.08622216999999999 -0.018" rpy="0.0 -0.0 0.0" />
        <parent link="upper_level_link" />
        <child link="range_right_link" />
    </joint>

    <!-- ==================== WHEEL FRICTION ==================== -->
    <!-- fdir1 sets the free-rolling direction for each mecanum wheel.
         The pattern (diagonal direction) must match the physical roller angle. -->
    <gazebo reference="wheel_rr_link">
        <collision>
            <surface><friction><ode>
                <mu>1.5</mu><mu2>0.0</mu2>
                <fdir1 gz:expressed_in="base_footprint">1 -1 0</fdir1>
            </ode></friction></surface>
        </collision>
    </gazebo>
    <gazebo reference="wheel_rl_link">
        <collision>
            <surface><friction><ode>
                <mu>1.5</mu><mu2>0.0</mu2>
                <fdir1 gz:expressed_in="base_footprint">1 1 0</fdir1>
            </ode></friction></surface>
        </collision>
    </gazebo>
    <gazebo reference="wheel_fr_link">
        <collision>
            <surface><friction><ode>
                <mu>1.5</mu><mu2>0.0</mu2>
                <fdir1 gz:expressed_in="base_footprint">1 1 0</fdir1>
            </ode></friction></surface>
        </collision>
    </gazebo>
    <gazebo reference="wheel_fl_link">
        <collision>
            <surface><friction><ode>
                <mu>1.5</mu><mu2>0.0</mu2>
                <fdir1 gz:expressed_in="base_footprint">1 -1 0</fdir1>
            </ode></friction></surface>
        </collision>
    </gazebo>

    <!-- ==================== IMU SENSOR ==================== -->
    <gazebo reference="imu_link">
        <sensor name="imu_sensor" type="imu">
            <always_on>true</always_on>
            <update_rate>100</update_rate>
            <topic>/imu</topic>
            <imu>
                <angular_velocity>
                    <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></z>
                </angular_velocity>
                <linear_acceleration>
                    <x><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></z>
                </linear_acceleration>
            </imu>
        </sensor>
    </gazebo>

    <!-- ==================== LIDAR SENSOR ==================== -->
    <!-- Attached to the `laser` link, which is already positioned by the URDF
         kinematic chain (base_link → upper_level_link → [Upper-Level_Revolute-3]
         → lidar_mount_link → laser). Tilt in sim matches the real robot exactly. -->
    <gazebo reference="laser">
        <sensor name="lidar" type="gpu_lidar">
            <always_on>true</always_on>
            <update_rate>10</update_rate>
            <visualize>true</visualize>
            <topic>/scan</topic>
            <gz_frame_id>laser</gz_frame_id>
            <lidar>
                <scan>
                    <horizontal>
                        <samples>450</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                    <vertical>
                        <samples>1</samples>
                        <resolution>1</resolution>
                        <min_angle>0.0</min_angle>
                        <max_angle>0.0</max_angle>
                    </vertical>
                </scan>
                <range>
                    <min>0.12</min>
                    <max>12.0</max>
                    <resolution>0.01</resolution>
                </range>
            </lidar>
        </sensor>
    </gazebo>

    <!-- ==================== GAZEBO PLUGINS ==================== -->
    <gazebo>
        <!-- Mecanum drive: subscribes /cmd_vel, publishes odometry and TF.
             Wheelbase and wheel_separation are approximate — tune if drift is observed. -->
        <plugin filename="gz-sim-mecanum-drive-system"
                name="gz::sim::systems::MecanumDrive">
            <front_left_joint>Motor-FL_Revolute-28</front_left_joint>
            <front_right_joint>Motor-FR_Revolute-27</front_right_joint>
            <back_left_joint>Motor-RL_Revolute-26</back_left_joint>
            <back_right_joint>Motor-RR_Revolute-22</back_right_joint>
            <wheelbase>0.100</wheelbase>
            <wheel_separation>0.145</wheel_separation>
            <wheel_radius>0.0375</wheel_radius>
            <topic>/cmd_vel</topic>
            <odom_topic>/wheel/odometry</odom_topic>
            <tf_topic>/model/gregor/tf</tf_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_footprint</child_frame_id>
            <odom_publish_frequency>50</odom_publish_frequency>
        </plugin>

        <!-- Publishes all joint states so robot_state_publisher and RViz stay in sync -->
        <plugin filename="gz-sim-joint-state-publisher-system"
                name="gz::sim::systems::JointStatePublisher">
        </plugin>

        <!-- Tilt joint position controller: receives /lidar_cmd_pos -->
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>Upper-Level_Revolute-3</joint_name>
            <topic>/lidar_cmd_pos</topic>
            <p_gain>10.0</p_gain>
            <i_gain>0.1</i_gain>
            <d_gain>0.1</d_gain>
        </plugin>
    </gazebo>
</robot>