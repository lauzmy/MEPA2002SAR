    </link>
    <link name="motor_fl_link">
        <inertial>
            <origin xyz="1.1990408665951691e-16 0.02494272119373083 2.1505034375479682e-09" rpy="0.0 -0.0 0.0" />
            <mass value="0.15441088816550527" />
            <inertia ixx="2.671247540468396e-05" iyy="1.2042060245804308e-05" izz="2.6712475404642815e-05" ixy="-2.710505431213761e-20" iyz="1.0842021724855044e-18" ixz="5.421010862427522e-20" />
        </inertial>
        <visual name="Motor-FL_visual">
            <origin xyz="-0.020062164065097535 0.0019829959975857037 2.1678969464034028e-09" rpy="1.5707963267948966 6.56419363309624e-15 1.5707963267948966" />
            <geometry>
                <mesh filename="package://gregor_description/meshes/Motor-FL.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="Motor-FL_collision">
            <origin xyz="-0.020062164065097535 0.0019829959975857037 2.1678969464034028e-09" rpy="1.5707963267948966 6.56419363309624e-15 1.5707963267948966" />
            <geometry>
                <mesh filename="package://gregor_description/meshes/Motor-FL.stl" scale="0.001 0.001 0.001" />
            </geometry>
