        <collision name="Motor-RR_collision">
            <origin xyz="-0.020062164065097577 -0.0019829992810189534 -1.220662504408665e-09" rpy="-1.5707963267948966 5.551115123125783e-17 -1.5707963267948966" />
            <geometry>
