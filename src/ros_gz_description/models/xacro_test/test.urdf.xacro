<?xml version="1.0"?>
<robot name="rrbot" xmlns:xacro="http://www.ros.org/wiki/xacro"
                    xmlns:gz="http://gazebosim.org/schema">


  <!-- ==================== PARAMETERS ==================== -->
  <!-- Pi constant -->
  <xacro:property name="pi_const" value="3.141592653589793"/>

  <!-- Body dimensions -->
  <xacro:property name="a" value="0.22"/>
  <xacro:property name="b" value="0.1"/>
  <xacro:property name="c" value="0.1"/>

  <!-- Wheel and caster dimensions -->
  <!-- Wheel and caster radius -->
  <xacro:property name="r" value="0.0375"/>
  <!-- Wheel width -->
  <xacro:property name="d" value="0.043"/>


  <xacro:property name="s1" value="${b/2+r}"/>
  <xacro:property name="s2" value="${2*r}"/>
  <xacro:property name="s3" value="${2*r}"/>
  <xacro:property name="s4" value="${c/2+d/2}"/>
  <xacro:property name="s5" value="${b/2}"/>


  <!-- ==================== MASS AND INERTIA ==================== -->

  <!-- Material density -->
  <!-- Body material density -->
  <xacro:property name="d1" value="2710.0"/>
  <!-- Wheel material density -->
  <xacro:property name="d2" value="2710.0"/>
  <!-- Caster material density -->
  <xacro:property name="d3" value="2710.0"/>

  <!-- Robot body mass, wheel mass and caster mass -->
  <!-- Body mass -->
  <xacro:property name="m1" value="${d1*a*b*c}"/>
  <!-- Wheel mass -->
  <xacro:property name="m2" value="${d2*pi_const*r*r*d}"/>
  <!-- Caster mass -->
  <xacro:property name="m3" value="${d3*4/3*pi_const*r*r*r}"/>

  <!-- Moment of inertia of robot body -->
  <xacro:property name="Ix_body" value="${m1*(b*b+c*c)/12}"/>
  <xacro:property name="Iy_body" value="${m1*(a*a+c*c)/12}"/>
  <xacro:property name="Iz_body" value="${m1*(a*a+b*b)/12}"/>

  <!-- Moment of inertia of wheel -->
  <xacro:property name="Iz_wheel" value="${m2*r*r/2}"/>
  <xacro:property name="I_wheel" value="${m2*(3*r*r + d*d)/12}"/>



  <!-- This macro defines the inertia properties for the robot body -->
  <xacro:macro name="inertial_body">
    <inertial>
    <origin rpy=" 0 0 0" xyz="0 0 ${s1}"/>
    <mass value="${m1}"/>
    <inertia ixx="${Ix_body}" ixy="0" ixz="0" iyy="${Iy_body}" iyz="0" izz="${Iz_body}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertial_wheel">
    <inertial>
    <origin rpy="1.570795 0 0" xyz="0 0 0"/>
    <mass value="${m2}"/>
    <inertia ixx="${I_wheel}" ixy="0" ixz="0" iyy="${I_wheel}" iyz="0" izz="${Iz_wheel}"/>
    </inertial>
  </xacro:macro>


  <!-- ==================== LINKS AND JOINTS ==================== -->

  <link name="base_footprint"/>
  
  <joint name="body_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="body_link"/>
  </joint>


  <!-- Body link -->
  <link name="body_link">
    <visual>
      <geometry>
        <box size="${a} ${c} ${b}"/>
      </geometry>
      <origin xyz="0 0 ${s1}" rpy="0 0 0"/>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <box size="${a} ${c} ${b}"/>
      </geometry>
      <origin xyz="0 0 ${s1}" rpy="0 0 0"/>
    </collision>  

    <xacro:inertial_body/>
  </link>

  <!-- Back right wheel link -->
  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="body_link"/>
    <child link="rear_right_wheel_link"/>
    <origin xyz="${-s2} ${-s4} ${r}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50000" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <link name="rear_right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.570795 0 0"/>
      <geometry>
        <cylinder radius="${r}" length="${d}"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 1.0 0.0 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.570795 0 0"/>
      <geometry>
        <cylinder radius="${r}" length="${d}"/>
      </geometry>
    </collision>

    <xacro:inertial_wheel/>
  </link>

  <!-- Back left wheel link -->
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="body_link"/>
    <child link="rear_left_wheel_link"/>
    <origin xyz="${-s2} ${s4} ${r}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50000" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <link name="rear_left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.570795 0 0"/>
      <geometry>
        <cylinder radius="${r}" length="${d}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.570795 0 0"/>
      <geometry>
        <cylinder radius="${r}" length="${d}"/>
      </geometry>
    </collision>

    <xacro:inertial_wheel/>
  </link>

  <!-- Front right wheel link -->
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="body_link"/>
    <child link="front_right_wheel_link"/>
    <origin xyz="${s2} ${-s4} ${r}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50000" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <link name="front_right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.570795 0 0"/>
      <geometry>
        <cylinder radius="${r}" length="${d}"/>
      </geometry>
      <material name="yellow">
        <color rgba="1.0 1.0 0.0 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.570795 0 0"/>
      <geometry>
        <cylinder radius="${r}" length="${d}"/>
      </geometry>
    </collision>

    <xacro:inertial_wheel/>
  </link>

  <!-- Front left wheel link -->
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="body_link"/>
    <child link="front_left_wheel_link"/>
    <origin xyz="${s2} ${s4} ${r}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50000" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <link name="front_left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.570795 0 0"/>
      <geometry>
        <cylinder radius="${r}" length="${d}"/>
      </geometry>
      <material name="magenta">
        <color rgba="1.0 0.0 1.0 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.570795 0 0"/>
      <geometry>
        <cylinder radius="${r}" length="${d}"/>
      </geometry>
    </collision>

    <xacro:inertial_wheel/>
  </link>


  <!-- Friction parameters for wheels -->
    <gazebo reference='rear_right_wheel_link'>
    <collision>
      <surface>
        <friction><ode><mu>1.5</mu><mu2>0.0</mu2><fdir1 gz:expressed_in="base_footprint">1 -1 0</fdir1></ode></friction>
      </surface>
    </collision>
  </gazebo>

    <gazebo reference='rear_left_wheel_link'>
    <collision>
      <surface>
        <friction><ode><mu>1.5</mu><mu2>0.0</mu2><fdir1 gz:expressed_in="base_footprint">1 1 0</fdir1></ode></friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference='front_right_wheel_link'>
    <collision>
      <surface>
        <friction><ode><mu>1.5</mu><mu2>0.0</mu2><fdir1 gz:expressed_in="base_footprint">1 1 0</fdir1></ode></friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference='front_left_wheel_link'>
    <collision>
      <surface>
        <friction><ode><mu>1.5</mu><mu2>0.0</mu2><fdir1 gz:expressed_in="base_footprint">1 -1 0</fdir1></ode></friction>
      </surface>
    </collision>
  </gazebo>





  <!-- LiDAR link -->
  <joint name="lidar_joint" type="fixed">
    <parent link="body_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 ${s1+s5}" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- Gazebo sensor on lidar_link -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>true</visualize>
      <topic>/scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.10</min_angle>
            <max_angle>0.10</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
    </sensor>
  </gazebo>


    <!-- Camera link -->
  <joint name="camera_joint" type="fixed">
    <parent link="body_link"/>
    <child link="camera_link"/>
    <origin xyz="${a/2} 0 ${s1}" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.06 0.04 0.04"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.04 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Gazebo camera sensor -->
  <gazebo reference="camera_link">
    <sensor name="front_thermal_camera" type="thermal_camera">
      <always_on>true</always_on>
      <update_rate>20</update_rate>
      <visualize>true</visualize>
      <topic>/camera/thermal/image_raw</topic>
      <camera_info_topic>/camera/thermal/camera_info</camera_info_topic>
      <thermal_camera>
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>L16</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>50.0</far>
        </clip>
        <min_temp>293.15</min_temp>   <!-- 20 C -->
        <max_temp>373.15</max_temp>   <!-- 100 C -->
        <resolution>0.1</resolution>  <!-- K per level -->
      </thermal_camera>
    </sensor>
  </gazebo>

    <!-- IMU link -->
  <joint name="imu_joint" type="fixed">
    <parent link="body_link"/>
    <child link="imu_link"/>
    <origin xyz="0.1 0 ${s1 + s5}" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <!-- Gazebo IMU sensor -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>/imu</topic>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>





  <!-- ==================== GAZEBO PLUGINS ==================== -->

  <gazebo>
    <!-- MecanumDrive plugin -->
    <plugin filename="gz-sim-mecanum-drive-system"
            name="gz::sim::systems::MecanumDrive">

      <front_left_joint>front_left_wheel_joint</front_left_joint>
      <front_right_joint>front_right_wheel_joint</front_right_joint>
      <back_left_joint>rear_left_wheel_joint</back_left_joint>
      <back_right_joint>rear_right_wheel_joint</back_right_joint>

      <wheelbase>${2*s2}</wheelbase>               <!-- front-back distance -->
      <wheel_separation>${2*s4}</wheel_separation> <!-- left-right distance -->
      <wheel_radius>${r}</wheel_radius>

      <topic>/model/test_robot/cmd_vel</topic>
      <odom_topic>/model/test_robot/odometry</odom_topic>
      <tf_topic>/model/test_robot/tf</tf_topic>

      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>
  
    <!-- JointStatePublisher plugin -->
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher"/>
  </gazebo>
</robot>